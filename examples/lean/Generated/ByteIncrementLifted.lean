import SVM.SBPF.Decode
import SVM.SBPF.RunnerBridge
import SVM.SBPF.Macros

namespace Examples.Lifted.ByteIncrementLifted

open SVM.SBPF

/-- `.text` bytes extracted from the .so by qedlift. -/
def ByteIncrementLiftedBytes : ByteArray := ⟨#[
  0x71, 0x12, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 
  0x07, 0x02, 0x00, 0x00, 0x01, 0x00, 0x00, 0x00, 
  0x73, 0x21, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 
  0xb7, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 
  0x95, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00
]⟩

/-- Text section file-offset: 0x100000120. -/
def ByteIncrementLiftedTextOffset : Nat := 0x100000120

/-- Decoded form of the .text bytes. -/
def ByteIncrementLiftedInsns : Array Insn := #[
  .ldx .byte .r2 .r1 0,
  .add64 .r2 (.imm 1),
  .stx .byte .r1 0 .r2,
  .mov64 .r0 (.imm 0),
  .exit
]

/-- The bytes decode exactly to the expected instruction array. -/
theorem ByteIncrementLifted_decodes :
    Decode.decodeProgram ByteIncrementLiftedBytes = some ByteIncrementLiftedInsns := by
  native_decide

/-! ## Hoare-triple skeleton (next iteration: symbolic executor)

The shape below is what qedlift would emit for the lift's
**theorem statement**. Pre/post atom synthesis from the
decoded insns is the next iteration's work; for now this
file demonstrates the bytes → decoded → ready-to-prove
