import SVM.SBPF.Decode
import SVM.SBPF.RunnerBridge
import SVM.SBPF.Macros
import SVM.SBPF.SatWitness

set_option maxRecDepth 65536
set_option maxHeartbeats 4000000

namespace Examples.Lifted.OobSetReturnData

open SVM.SBPF

-- NOTE: `OobSetReturnDataBytes` + `OobSetReturnDataInsns` + `OobSetReturnData_decodes` omitted — the .text
-- is 40 bytes, which blows `maxRecDepth` as a ByteArray literal.
-- The byte→insn link is pinned instead by `OobSetReturnData_decode_pins` below:
-- the `.text` is embedded as a hex string (`OobSetReturnDataText`) and every
-- walked PC's decode is checked by `native_decide` against the
-- exact instruction the Hoare triple's `CodeReq` claims there
-- (soundness-audit H8).

/-- The `.text` bytes of the binary, embedded as hex (whitespace-insensitive;
    see `Decode.bytesOfHex`). 40 bytes. -/
def OobSetReturnDataText : ByteArray := Decode.bytesOfHex "
  0701000000000010b70200000800000085100000ebd326a2b7000000000000009500000000000000
  "

/-- Byte-slot → logical-PC map for `OobSetReturnDataText` (pass 1 of the decoder),
    computed in-kernel — jump-target resolution in the pins below depends on
    the `lddw` positions of the WHOLE text, not just the pinned windows. -/
def OobSetReturnDataSlotMap : Array Nat := Decode.buildSlotMap OobSetReturnDataText

/-- The V0 function registry (murmur3 key → target slot) solana-sbpf built
    at load, mirroring `Elf.buildFnRegistry` (audit H2). Resolves internal
    `call` immediates in the pins below to `.call_local` targets. -/
def OobSetReturnDataFnRegistry : List (Nat × Nat) := [(1910755201, 0)]

/-- Walked-PC decode pins (soundness-audit H8 + H2): every instruction the
    Hoare triple's `CodeReq` claims at a walked PC is the decode of the
    `.text` bytes at that PC's byte offset, checked end-to-end in-kernel
    (`bytesOfHex` → `buildSlotMap` → `decodeInsn` with the function registry) by
    `native_decide`. Internal `call_local` PCs are included — their murmur3
    imm resolves through `OobSetReturnDataFnRegistry`. -/
theorem OobSetReturnData_decode_pins :
    ([0, 8].map fun off =>
      Decode.decodeInsn OobSetReturnDataText OobSetReturnDataSlotMap off OobSetReturnDataFnRegistry) = [
      some (.add64 .r1 (.imm (268435456)), 8),
      some (.mov64 .r2 (.imm (8)), 8)
    ] := by
  native_decide

/-! ## Symbolically lifted Hoare triple

Synthesised by qedlift's symbolic executor walking the
decoded insns left-to-right. Closed by `sl_block_auto`. -/

open Memory in
theorem OobSetReturnData_lifted_spec
    (baseAddr vR2Old : Nat)
    : cuTripleWithinMem 2 0 0 2
      (((CodeReq.singleton 0 (.add64 .r1 (.imm (268435456)))).union
        (CodeReq.singleton 1 (.mov64 .r2 (.imm (8))))))
      ((.r1 ↦ᵣ baseAddr) **
      (.r2 ↦ᵣ vR2Old))
      ((.r1 ↦ᵣ wrapAdd baseAddr (toU64 268435456)) **
      (.r2 ↦ᵣ toU64 8))
      (fun rt => True) := by
  sl_block_auto

/-! ## Satisfiability witness (soundness-audit H8)

The triple's precondition is SATISFIABLE at the concrete
assignment below — an overlapping (vacuous) sepConj would fail
`native_decide` here, so vacuity cannot ship. The guards pin
each `addrK` literal to its `h_addrK` defining equation at the
assignment; the witness goal is the theorem's precondition with
the variables instantiated, so the reflected `SatWitness` atoms
are tied to the real pre by the elaborator's defeq check.
Value-level path hypotheses (`h_branch*`) are not certified
consistent — they are outside the overlap-vacuity class this
guards against. -/

open Memory in
example : ∃ s,
    ((.r1 ↦ᵣ 0) **
      (.r2 ↦ᵣ 0)) s := by
  have w := SatWitness.sat_witness
    [.reg .r1 0,
     .reg .r2 0]
    (by native_decide)
  exact w

open Memory in
theorem OobSetReturnData_fault_correct
    (baseAddr vR2Old : Nat)
    (nCuOob : Nat)
    (hCuOob : ∀ s : State,
        (step (.call .sol_set_return_data) s).cuConsumed ≤ s.cuConsumed + nCuOob)
    : cuTripleFaultsWithinMem (2 + 1) (0 + nCuOob) 0
      ((((CodeReq.singleton 0 (.add64 .r1 (.imm (268435456)))).union
        (CodeReq.singleton 1 (.mov64 .r2 (.imm (8)))))).union
        (CodeReq.singleton 2 (.call .sol_set_return_data)))
      ((.r1 ↦ᵣ baseAddr) **
      (.r2 ↦ᵣ vR2Old))
      (fun rt => (True) ∧ rt.containsRange (wrapAdd baseAddr (toU64 268435456)) (toU64 8) = false)
      .accessViolation := by
  refine cuTripleWithinMem_seq_fault ?_ (OobSetReturnData_lifted_spec baseAddr vR2Old) (call_sol_set_return_data_faults_oob_spec (wrapAdd baseAddr (toU64 268435456)) (toU64 8) (by decide) (by decide) 2 nCuOob hCuOob)
  repeat' apply CodeReq.Disjoint_union_left
  all_goals exact CodeReq.singleton_disjoint_singleton _ _ (by decide)

