/-! ## Symbolically lifted Hoare triple

Synthesised by qedlift's symbolic executor walking the
decoded insns left-to-right. Closed by `sl_block_auto`. -/

open Memory in
theorem GuardedOobOob_lifted_spec
    (baseAddr oldMemD_0 vR2Old : Nat)
    (holdMemD_0_lt : oldMemD_0 < 2 ^ 64)
    (h_branch0 : oldMemD_0 = toU64 0)
    : cuTripleWithinMem 3 0 0 8
      ((((CodeReq.singleton 0 (.ldx .dword .r2 .r1 0)).union
        (CodeReq.singleton 1 (.jeq .r2 (.imm (0)) 7))).union
        (CodeReq.singleton 7 (.add64 .r1 (.imm (268435456))))))
      ((.r1 ↦ᵣ baseAddr) **
      (effectiveAddr baseAddr 0 ↦U64 oldMemD_0) **
      (.r2 ↦ᵣ vR2Old))
      ((.r1 ↦ᵣ wrapAdd baseAddr (toU64 268435456)) **
      (effectiveAddr baseAddr 0 ↦U64 oldMemD_0) **
      (.r2 ↦ᵣ oldMemD_0))
      (fun rt => rt.containsRange (effectiveAddr baseAddr 0) 8 = true) := by
  have h_0 := ldxdw_spec .r2 .r1 0 (vR2Old) (baseAddr) oldMemD_0 0 (by decide) holdMemD_0_lt
  have h_1 := jeq_imm_taken_spec .r2 0 (oldMemD_0) 1 7 h_branch0
  have h_7 := add64_imm_spec .r1 268435456 (baseAddr) 7 (by decide)
  sl_block_iter [h_0, h_1, h_7] generalizing [wrapAdd baseAddr (toU64 268435456)]

/-! ## Satisfiability witness (soundness-audit H8)

The triple's precondition is SATISFIABLE at the concrete
assignment below — an overlapping (vacuous) sepConj would fail
`native_decide` here, so vacuity cannot ship. The guards pin
each `addrK` literal to its `h_addrK` defining equation at the
assignment; the witness goal is the theorem's precondition with
the variables instantiated, so the reflected `SatWitness` atoms
are tied to the real pre by the elaborator's defeq check.
Value-level path hypotheses (`h_branch*`) are not certified
consistent — they are outside the overlap-vacuity class this
guards against. -/

open Memory in
example : ∃ s,
    ((.r1 ↦ᵣ 17179869184) **
      (effectiveAddr 17179869184 0 ↦U64 0) **
      (.r2 ↦ᵣ 0)) s := by
  have w := SatWitness.sat_witness
    [.reg .r1 17179869184,
     .u64 17179869184 0,
     .reg .r2 0]
    (by native_decide)
  exact w

/-! ## Branch-satisfiability witness (Phase 7 sub-item 1)

The triple's value-level path hypotheses (`h_branch*`) and load
bounds (`h*_lt`) are uncertified parameters — an UNSATISFIABLE
conjunction of them would make the triple vacuously true. The
assignment below satisfies every (modeled) path hypothesis
SIMULTANEOUSLY; `native_decide` machine-checks it, so a
contradictory path-constraint set cannot ship silently. This
complements the H8 footprint witness above (disjoint variable
sets: address roots vs. discriminant/flag cells). -/

example :
      (0 = toU64 0) ∧
      (0 < 2 ^ 64) := by
  refine ⟨?_, ?_⟩ <;> native_decide

open Memory in
theorem GuardedOobOob_fault_correct
    (baseAddr oldMemD_0 vR2Old : Nat)
    (holdMemD_0_lt : oldMemD_0 < 2 ^ 64)
    (h_branch0 : oldMemD_0 = toU64 0)
    (nCuOob : Nat)
    (hCuOob : ∀ s : State,
        (step (.call .sol_get_clock_sysvar) s).cuConsumed ≤ s.cuConsumed + nCuOob)
    : cuTripleFaultsWithinMem (3 + 1) (0 + nCuOob) 0
      (((((CodeReq.singleton 0 (.ldx .dword .r2 .r1 0)).union
        (CodeReq.singleton 1 (.jeq .r2 (.imm (0)) 7))).union
        (CodeReq.singleton 7 (.add64 .r1 (.imm (268435456)))))).union
        (CodeReq.singleton 8 (.call .sol_get_clock_sysvar)))
      ((.r1 ↦ᵣ baseAddr) **
      (effectiveAddr baseAddr 0 ↦U64 oldMemD_0) **
      (.r2 ↦ᵣ vR2Old))
      (fun rt => (rt.containsRange (effectiveAddr baseAddr 0) 8 = true) ∧ rt.containsWritable (wrapAdd baseAddr (toU64 268435456)) 40 = false)
      .accessViolation := by
  refine cuTripleWithinMem_seq_fault ?_ (GuardedOobOob_lifted_spec baseAddr oldMemD_0 vR2Old holdMemD_0_lt h_branch0) (cuTripleFaultsWithinMem_frame_right ((effectiveAddr baseAddr 0 ↦U64 oldMemD_0) **
      (.r2 ↦ᵣ oldMemD_0))
      (by repeat' apply pcFree_sepConj
          all_goals first
            | exact pcFree_regIs _ _
            | exact pcFree_memU64Is _ _
            | exact pcFree_memU32Is _ _
            | exact pcFree_memU16Is _ _
            | exact pcFree_memByteIs _ _
            | exact pcFree_memBytes32Is _ _
            | exact pcFree_memBytesIs _ _)
      (call_sol_get_clock_sysvar_faults_oob_spec (wrapAdd baseAddr (toU64 268435456)) 8 nCuOob hCuOob))
  repeat' apply CodeReq.Disjoint_union_left
  all_goals exact CodeReq.singleton_disjoint_singleton _ _ (by decide)


/-! ## Whole-transition FAULT-path corollary (#40)

One fault PATH of the account GuardedOob (handler credit) transition: the running
prefix (`GuardedOobOob_lifted_spec`) composed with the terminal `.sol_get_clock_sysvar` fault — the program
FAULTS with the typed `.accessViolation` (`exitCode = some toSentinel ∧ vmError =
some .accessViolation`), the tracked account codec owned in the pre (no post: a
faulted instruction is rolled back wholesale; tracked cells outside the
prefix footprint are framed through it). -/

open Memory in
set_option maxHeartbeats 1600000 in
theorem GuardedOobOob_transition_fault
    (baseAddr oldMemD_0 vR2Old : Nat)
    (holdMemD_0_lt : oldMemD_0 < 2 ^ 64)
    (h_branch0 : oldMemD_0 = toU64 0)
    (counter : Nat)
    (nCuAbort : Nat)
    (hCuAbort : ∀ s : State,
        (step (.call .sol_get_clock_sysvar) s).cuConsumed ≤ s.cuConsumed + nCuAbort)
    : SVM.Solana.Abstract.AsmRefinesTransitionFault
      (((((CodeReq.singleton 0 (.ldx .dword .r2 .r1 0)).union
        (CodeReq.singleton 1 (.jeq .r2 (.imm (0)) 7))).union
        (CodeReq.singleton 7 (.add64 .r1 (.imm (268435456)))))).union
        (CodeReq.singleton 8 (.call .sol_get_clock_sysvar)))
      (3 + 1) (0 + nCuAbort) 0
      (fun rt => (rt.containsRange (effectiveAddr baseAddr 0) 8 = true) ∧ rt.containsWritable (wrapAdd baseAddr (toU64 268435456)) 40 = false)
      (.accessViolation)
      [(baseAddr,
        [(8, .u64 counter)],
        [(8, .u64 counter)])]
      ((.r1 ↦ᵣ baseAddr) **
      (effectiveAddr baseAddr 0 ↦U64 oldMemD_0) **
      (.r2 ↦ᵣ vR2Old)) := by
  unfold SVM.Solana.Abstract.AsmRefinesTransitionFault
  simp only [SVM.Solana.Abstract.codecsPre,
             codecCoarse, FieldVal.coarse, sepConj_emp_right_eq, Nat.add_zero]
  refine cuTripleWithinMem_seq_fault ?_ ?_
    (cuTripleFaultsWithinMem_frame_right
      (((effectiveAddr baseAddr 0 ↦U64 oldMemD_0) **
      (.r2 ↦ᵣ oldMemD_0)) **
       ((effectiveAddr baseAddr 8 ↦U64 counter)))
      (by repeat' apply pcFree_sepConj
          all_goals first
            | exact pcFree_regIs _ _
            | exact pcFree_memU64Is _ _
            | exact pcFree_memU32Is _ _
            | exact pcFree_memU16Is _ _
            | exact pcFree_memByteIs _ _
            | exact pcFree_memBytes32Is _ _
            | exact pcFree_memBytesIs _ _)
      (call_sol_get_clock_sysvar_faults_oob_spec (wrapAdd baseAddr (toU64 268435456)) 8 nCuAbort hCuAbort))
  · repeat' apply CodeReq.Disjoint_union_left
    all_goals exact CodeReq.singleton_disjoint_singleton _ _ (by decide)
  · have framed := cuTripleWithinMem_frame_right
      ( (effectiveAddr baseAddr 8 ↦U64 counter) )
      (by sl_pcfree) (GuardedOobOob_lifted_spec baseAddr oldMemD_0 vR2Old holdMemD_0_lt h_branch0)
    sl_exact framed
end Examples.Lifted.GuardedOobOob
