/-
  Generated by `qedlift` from `tests/fixtures/set_return_data_caller.so`.

End-to-end lift demonstration:
1. The .text bytes are embedded as a hex string
(`Decode.bytesOfHex`; a `ByteArray` literal this large
blows `maxRecDepth`).
2. The full `decodeProgram` bridge is omitted; instead the
`_decode_pins` theorem pins the decode of every walked
PC's bytes by `native_decide`, threading the V0 function
registry so internal `call_local` PCs resolve (audit H2).
3. A `cuTripleWithinMem` Hoare triple is stated over the
decoded sequence. The pre/post atom synthesis is the next
iteration's work (the "symbolic executor" piece); for the
demo, see the worked example in
`SVM/SBPF/Macros.lean` (`set_return_data_caller_macro_spec_auto`) where the
theorem is proved by `sl_block_auto` against the same
instruction sequence.
-/

import SVM.SBPF.Decode
import SVM.SBPF.RunnerBridge
import SVM.SBPF.Macros
import SVM.SBPF.SatWitness

set_option maxRecDepth 65536
set_option maxHeartbeats 4000000

namespace Examples.Lifted.SetReturnData

open SVM.SBPF

-- NOTE: `SetReturnDataBytes` + `SetReturnDataInsns` + `SetReturnData_decodes` omitted — the .text
-- is 48 bytes, which blows `maxRecDepth` as a ByteArray literal.
-- The byte→insn link is pinned instead by `SetReturnData_decode_pins` below:
-- the `.text` is embedded as a hex string (`SetReturnDataText`) and every
-- walked PC's decode is checked by `native_decide` against the
-- exact instruction the Hoare triple's `CodeReq` claims there
-- (soundness-audit H8).

/-- The `.text` bytes of the binary, embedded as hex (whitespace-insensitive;
    see `Decode.bytesOfHex`). 48 bytes. -/
def SetReturnDataText : ByteArray := Decode.bytesOfHex "
  18010000000000000000000003000000b70200001000000085100000ebd326a2b7000000000000009500000000000000
  "

/-- Byte-slot → logical-PC map for `SetReturnDataText` (pass 1 of the decoder),
    computed in-kernel — jump-target resolution in the pins below depends on
    the `lddw` positions of the WHOLE text, not just the pinned windows. -/
def SetReturnDataSlotMap : Array Nat := Decode.buildSlotMap SetReturnDataText

/-- The V0 function registry (murmur3 key → target slot) solana-sbpf built
    at load, mirroring `Elf.buildFnRegistry` (audit H2). Resolves internal
    `call` immediates in the pins below to `.call_local` targets. -/
def SetReturnDataFnRegistry : List (Nat × Nat) := [(1910755201, 0)]

/-- Walked-PC decode pins (soundness-audit H8 + H2): every instruction the
    Hoare triple's `CodeReq` claims at a walked PC is the decode of the
    `.text` bytes at that PC's byte offset, checked end-to-end in-kernel
    (`bytesOfHex` → `buildSlotMap` → `decodeInsn` with the function registry) by
    `native_decide`. Internal `call_local` PCs are included — their murmur3
    imm resolves through `SetReturnDataFnRegistry`. -/
theorem SetReturnData_decode_pins :
    ([0, 16, 24, 32].map fun off =>
      Decode.decodeInsn SetReturnDataText SetReturnDataSlotMap off SetReturnDataFnRegistry) = [
      some (.lddw .r1 (12884901888), 16),
      some (.mov64 .r2 (.imm (16)), 8),
      some (.call .sol_set_return_data, 8),
      some (.mov64 .r0 (.imm (0)), 8)
    ] := by
  native_decide

/-! ## Symbolically lifted Hoare triple

Synthesised by qedlift's symbolic executor walking the
decoded insns left-to-right. Closed by `sl_block_auto`. -/

open Memory in
theorem SetReturnData_lifted_spec
    (baseAddr vR2Old vR0Old : Nat)
    (retDataOld_0 : ByteArray)
    (setRetData_0 : ByteArray)
    (hsetRetData_0_sz : setRetData_0.size = (toU64 16))
    (nCuSetRetData0 : Nat)
    (hCuSetRetData0 : ∀ s : State, (step (.call .sol_set_return_data) s).cuConsumed ≤ s.cuConsumed + nCuSetRetData0)
    : cuTripleWithinMem 4 nCuSetRetData0 0 4
      (((((CodeReq.singleton 0 (.lddw .r1 (12884901888))).union
        (CodeReq.singleton 1 (.mov64 .r2 (.imm (16))))).union
        (CodeReq.singleton 2 (.call .sol_set_return_data))).union
        (CodeReq.singleton 3 (.mov64 .r0 (.imm (0))))))
      ((.r1 ↦ᵣ baseAddr) **
      (.r2 ↦ᵣ vR2Old) **
      (.r0 ↦ᵣ vR0Old) **
      (toU64 12884901888 ↦Bytes setRetData_0) **
      (↦ReturnData retDataOld_0))
      ((.r1 ↦ᵣ toU64 12884901888) **
      (.r2 ↦ᵣ toU64 16) **
      (.r0 ↦ᵣ toU64 0) **
      (toU64 12884901888 ↦Bytes setRetData_0) **
      (↦ReturnData setRetData_0))
      (fun rt => rt.containsRange (toU64 12884901888) (toU64 16) = true) := by
  have h_0 := lddw_spec .r1 12884901888 (baseAddr) 0 (by decide)
  have h_1 := mov64_imm_spec .r2 16 (vR2Old) 1 (by decide)
  have h_2 := call_sol_set_return_data_spec vR0Old (toU64 12884901888) (toU64 16) 2 nCuSetRetData0 setRetData_0 retDataOld_0 hsetRetData_0_sz (by decide) hCuSetRetData0
  have h_3 := mov64_imm_spec .r0 0 (0) 3 (by decide)
  sl_block_iter [h_0, h_1, h_2, h_3]

/-! ## Satisfiability witness (soundness-audit H8)

The triple's precondition is SATISFIABLE at the concrete
assignment below — an overlapping (vacuous) sepConj would fail
`native_decide` here, so vacuity cannot ship. The guards pin
each `addrK` literal to its `h_addrK` defining equation at the
assignment; the witness goal is the theorem's precondition with
the variables instantiated, so the reflected `SatWitness` atoms
are tied to the real pre by the elaborator's defeq check.
Value-level path hypotheses (`h_branch*`) are not certified
consistent — they are outside the overlap-vacuity class this
guards against. -/

open Memory in
example : ∃ s,
    ((.r1 ↦ᵣ 0) **
      (.r2 ↦ᵣ 0) **
      (.r0 ↦ᵣ 0) **
      (toU64 12884901888 ↦Bytes (replicateByte 0 16)) **
      (↦ReturnData ByteArray.empty)) s := by
  have w := SatWitness.sat_witness
    [.reg .r1 0,
     .reg .r2 0,
     .reg .r0 0,
     .bytes 12884901888 (replicateByte 0 16),
     .retData ByteArray.empty]
    (by native_decide)
  exact w

end Examples.Lifted.SetReturnData
