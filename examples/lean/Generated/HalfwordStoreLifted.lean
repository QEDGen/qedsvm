/-! ## Symbolically lifted Hoare triple

Synthesised by qedlift's symbolic executor walking the
decoded insns left-to-right. Closed by `sl_block_auto`. -/

open Memory in
theorem HalfwordStore_lifted_spec
    (baseAddr oldMemH_0 vR2Old oldMemH_1 vR0Old : Nat)
    (holdMemH_0_lt : oldMemH_0 < 2 ^ 16)
    : cuTripleWithinMem 5 0 0 5
      ((((((CodeReq.singleton 0 (.ldx .half .r2 .r1 96)).union
        (CodeReq.singleton 1 (.add64 .r2 (.imm (1))))).union
        (CodeReq.singleton 2 (.stx .half .r1 96 .r2))).union
        (CodeReq.singleton 3 (.st .half .r1 98 (4660)))).union
        (CodeReq.singleton 4 (.mov64 .r0 (.imm (0))))))
      ((.r1 ↦ᵣ baseAddr) **
      (effectiveAddr baseAddr 96 ↦U16 oldMemH_0) **
      (.r2 ↦ᵣ vR2Old) **
      (effectiveAddr baseAddr 98 ↦U16 oldMemH_1) **
      (.r0 ↦ᵣ vR0Old))
      ((.r1 ↦ᵣ baseAddr) **
      (effectiveAddr baseAddr 96 ↦U16 wrapAdd oldMemH_0 (toU64 1)) **
      (.r2 ↦ᵣ wrapAdd oldMemH_0 (toU64 1)) **
      (effectiveAddr baseAddr 98 ↦U16 toU64 4660 % 2 ^ (2 * 8)) **
      (.r0 ↦ᵣ toU64 0))
      (fun rt => ((rt.containsRange (effectiveAddr baseAddr 96) 2 = true) ∧
                  rt.containsWritable (effectiveAddr baseAddr 96) 2 = true) ∧
                  rt.containsWritable (effectiveAddr baseAddr 98) 2 = true) := by
  sl_block_auto <;> assumption

/-! ## Satisfiability witness (soundness-audit H8)

The triple's precondition is SATISFIABLE at the concrete
assignment below — an overlapping (vacuous) sepConj would fail
`native_decide` here, so vacuity cannot ship. The guards pin
each `addrK` literal to its `h_addrK` defining equation at the
assignment; the witness goal is the theorem's precondition with
the variables instantiated, so the reflected `SatWitness` atoms
are tied to the real pre by the elaborator's defeq check.
Value-level path hypotheses (`h_branch*`) are not certified
consistent — they are outside the overlap-vacuity class this
guards against. -/

open Memory in
example : ∃ s,
    ((.r1 ↦ᵣ 17179869184) **
      (effectiveAddr 17179869184 96 ↦U16 0) **
      (.r2 ↦ᵣ 0) **
      (effectiveAddr 17179869184 98 ↦U16 0) **
      (.r0 ↦ᵣ 0)) s := by
  have w := SatWitness.sat_witness
    [.reg .r1 17179869184,
     .u16 17179869280 0,
     .reg .r2 0,
     .u16 17179869282 0,
     .reg .r0 0]
    (by native_decide)
  exact w

end Examples.Lifted.HalfwordStore
