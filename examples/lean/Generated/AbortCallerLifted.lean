/-
  Generated by `qedlift` from `tests/fixtures/abort_caller.so`.

End-to-end lift demonstration:
1. The .text bytes are embedded verbatim as a `ByteArray`.
2. `Decode.decodeProgram` recovers the instruction sequence;
`native_decide` proves the decode is correct.
3. A `cuTripleWithinMem` Hoare triple is stated over the
decoded sequence. The pre/post atom synthesis is the next
iteration's work (the "symbolic executor" piece); for the
demo, see the worked example in
`SVM/SBPF/Macros.lean` (`abort_caller_macro_spec_auto`) where the
theorem is proved by `sl_block_auto` against the same
instruction sequence.
-/

import SVM.SBPF.Decode
import SVM.SBPF.RunnerBridge
import SVM.SBPF.Macros
import SVM.SBPF.SatWitness

set_option maxRecDepth 65536
set_option maxHeartbeats 4000000

namespace Examples.Lifted.AbortCaller

open SVM.SBPF

/-- `.text` bytes extracted from the .so by qedlift. -/
def AbortCallerBytes : ByteArray := ⟨#[
  0x7a, 0x0a, 0xf8, 0xff, 0x05, 0x00, 0x00, 0x00, 
  0x79, 0xa1, 0xf8, 0xff, 0x00, 0x00, 0x00, 0x00, 
  0x85, 0x10, 0x00, 0x00, 0x11, 0x1a, 0xfc, 0xb6
]⟩

/-- Text section file-offset: 0x100000120. -/
def AbortCallerTextOffset : Nat := 0x100000120

/-- Decoded form of the .text bytes. -/
def AbortCallerInsns : Array Insn := #[
  .st .dword .r10 (-8) (5),
  .ldx .dword .r1 .r10 (-8),
  .call .abort
]

/-- The V0 function registry (murmur3 key → target slot) solana-sbpf built
    at load, mirroring `Elf.buildFnRegistry` (audit H2). Resolves internal
    `call` immediates to `.call_local` targets. -/
def AbortCallerFnRegistry : List (Nat × Nat) := [(1910755201, 0)]

/-- The bytes decode exactly to the expected instruction array. -/
theorem AbortCaller_decodes :
    Decode.decodeProgram AbortCallerBytes AbortCallerFnRegistry = some AbortCallerInsns := by
  native_decide

/-! ## Symbolically lifted Hoare triple

Synthesised by qedlift's symbolic executor walking the
decoded insns left-to-right. Closed by `sl_block_auto`. -/

open Memory in
theorem AbortCaller_lifted_spec
    (vR10Old oldMemD_0 baseAddr : Nat)
    (hReloadLt_1 : toU64 5 % 2 ^ (8 * 8) < 2 ^ 64)
    : cuTripleWithinMem 2 0 0 2
      (((CodeReq.singleton 0 (.st .dword .r10 (-8) (5))).union
        (CodeReq.singleton 1 (.ldx .dword .r1 .r10 (-8)))))
      ((.r10 ↦ᵣ vR10Old) **
      (effectiveAddr vR10Old (-8) ↦U64 oldMemD_0) **
      (.r1 ↦ᵣ baseAddr))
      ((.r10 ↦ᵣ vR10Old) **
      (effectiveAddr vR10Old (-8) ↦U64 toU64 5 % 2 ^ (8 * 8)) **
      (.r1 ↦ᵣ toU64 5 % 2 ^ (8 * 8)))
      (fun rt => (rt.containsWritable (effectiveAddr vR10Old (-8)) 8 = true) ∧
                  rt.containsRange (effectiveAddr vR10Old (-8)) 8 = true) := by
  sl_block_auto <;> assumption

/-! ## Satisfiability witness (soundness-audit H8)

The triple's precondition is SATISFIABLE at the concrete
assignment below — an overlapping (vacuous) sepConj would fail
`native_decide` here, so vacuity cannot ship. The guards pin
each `addrK` literal to its `h_addrK` defining equation at the
assignment; the witness goal is the theorem's precondition with
the variables instantiated, so the reflected `SatWitness` atoms
are tied to the real pre by the elaborator's defeq check.
Value-level path hypotheses (`h_branch*`) are not certified
consistent — they are outside the overlap-vacuity class this
guards against. -/

open Memory in
example : ∃ s,
    ((.r10 ↦ᵣ 17179869184) **
      (effectiveAddr 17179869184 (-8) ↦U64 0) **
      (.r1 ↦ᵣ 0)) s := by
  have w := SatWitness.sat_witness
    [.reg .r10 17179869184,
     .u64 17179869176 0,
     .reg .r1 0]
    (by native_decide)
  exact w

open Memory in
theorem AbortCaller_fault_correct
    (vR10Old oldMemD_0 baseAddr : Nat)
    (hReloadLt_1 : toU64 5 % 2 ^ (8 * 8) < 2 ^ 64)
    (nCuAbort : Nat)
    (hCuAbort : ∀ s : State,
        (step (.call .abort) s).cuConsumed ≤ s.cuConsumed + nCuAbort)
    : cuTripleFaultsWithinMem (2 + 1) (0 + nCuAbort) 0
      ((((CodeReq.singleton 0 (.st .dword .r10 (-8) (5))).union
        (CodeReq.singleton 1 (.ldx .dword .r1 .r10 (-8))))).union
        (CodeReq.singleton 2 (.call .abort)))
      ((.r10 ↦ᵣ vR10Old) **
      (effectiveAddr vR10Old (-8) ↦U64 oldMemD_0) **
      (.r1 ↦ᵣ baseAddr))
      (fun rt => (rt.containsWritable (effectiveAddr vR10Old (-8)) 8 = true) ∧
                  rt.containsRange (effectiveAddr vR10Old (-8)) 8 = true)
      .abort := by
  refine cuTripleWithinMem_seq_fault_pure ?_ (AbortCaller_lifted_spec vR10Old oldMemD_0 baseAddr hReloadLt_1) (call_abort_faults_spec ((.r10 ↦ᵣ vR10Old) **
      (effectiveAddr vR10Old (-8) ↦U64 toU64 5 % 2 ^ (8 * 8)) **
      (.r1 ↦ᵣ toU64 5 % 2 ^ (8 * 8))) 2 nCuAbort hCuAbort)
  repeat' apply CodeReq.Disjoint_union_left
  all_goals exact CodeReq.singleton_disjoint_singleton _ _ (by decide)

end Examples.Lifted.AbortCaller
