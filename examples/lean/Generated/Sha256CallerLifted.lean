-- (soundness-audit H8).

/-- The `.text` bytes of the binary, embedded as hex (whitespace-insensitive;
    see `Decode.bytesOfHex`). 128 bytes. -/
def Sha256CallerText : ByteArray := Decode.bytesOfHex "
  18010000000000000000000003000000180200000001000000000000030000007b21000000000000180100000800000000000000030000007a01000010000000
