open Memory in
theorem TwoOpIncrement_lifted_spec
    (baseAddr oldMemD_0 vR2Old oldMemB_1 vR3Old vR0Old : Nat)
    (holdMemD_0_lt : oldMemD_0 < 2 ^ 64)
    (h_branch0 : oldMemB_1 % 256 = toU64 1)
    : cuTripleWithinMem 6 0 0 9
      (((((((CodeReq.singleton 0 (.ldx .dword .r2 .r1 1)).union
        (CodeReq.singleton 1 (.ldx .byte .r3 .r1 0))).union
        (CodeReq.singleton 2 (.jeq .r3 (.imm (1)) 6))).union
        (CodeReq.singleton 6 (.add64 .r2 (.reg .r3)))).union
        (CodeReq.singleton 7 (.stx .dword .r1 1 .r2))).union
        (CodeReq.singleton 8 (.mov64 .r0 (.imm (0))))))
      ((.r1 ↦ᵣ baseAddr) **
      (effectiveAddr baseAddr 1 ↦U64 oldMemD_0) **
      (.r2 ↦ᵣ vR2Old) **
      (effectiveAddr baseAddr 0 ↦ₘ oldMemB_1) **
      (.r3 ↦ᵣ vR3Old) **
      (.r0 ↦ᵣ vR0Old))
      ((.r1 ↦ᵣ baseAddr) **
      (effectiveAddr baseAddr 1 ↦U64 wrapAdd oldMemD_0 (oldMemB_1 % 256)) **
      (.r2 ↦ᵣ wrapAdd oldMemD_0 (oldMemB_1 % 256)) **
      (effectiveAddr baseAddr 0 ↦ₘ oldMemB_1) **
      (.r3 ↦ᵣ oldMemB_1 % 256) **
      (.r0 ↦ᵣ toU64 0))
      (fun rt => ((rt.containsRange (effectiveAddr baseAddr 1) 8 = true) ∧
                  rt.containsRange (effectiveAddr baseAddr 0) 1 = true) ∧
                  rt.containsWritable (effectiveAddr baseAddr 1) 8 = true) := by
  have h_0 := ldxdw_spec .r2 .r1 1 (vR2Old) (baseAddr) oldMemD_0 0 (by decide) holdMemD_0_lt
  have h_1 := ldxb_spec .r3 .r1 0 (vR3Old) (baseAddr) oldMemB_1 1 (by decide)
  have h_2 := jeq_imm_taken_spec .r3 1 (oldMemB_1 % 256) 2 6 h_branch0
  have h_6 := add64_reg_spec .r2 .r3 (oldMemD_0) (oldMemB_1 % 256) 6 (by decide)
  have h_7 := stxdw_spec .r1 .r2 1 (baseAddr) (wrapAdd oldMemD_0 (oldMemB_1 % 256)) oldMemD_0 7
  have h_8 := mov64_imm_spec .r0 0 (vR0Old) 8 (by decide)
  sl_block_iter [h_0, h_1, h_2, h_6, h_7, h_8] generalizing [wrapAdd oldMemD_0 (oldMemB_1 % 256), oldMemB_1 % 256]

