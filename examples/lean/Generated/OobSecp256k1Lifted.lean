/-
  Generated by `qedlift` from `tests/fixtures/oob_secp256k1.so`.

End-to-end lift demonstration:
1. The .text bytes are embedded verbatim as a `ByteArray`.
2. `Decode.decodeProgram` recovers the instruction sequence;
`native_decide` proves the decode is correct.
3. A `cuTripleWithinMem` Hoare triple is stated over the
decoded sequence. The pre/post atom synthesis is the next
iteration's work (the "symbolic executor" piece); for the
demo, see the worked example in
`SVM/SBPF/Macros.lean` (`oob_secp256k1_macro_spec_auto`) where the
theorem is proved by `sl_block_auto` against the same
instruction sequence.
-/

import SVM.SBPF.Decode
import SVM.SBPF.RunnerBridge
import SVM.SBPF.Macros
import SVM.SBPF.SatWitness

set_option maxRecDepth 65536
set_option maxHeartbeats 4000000

namespace Examples.Lifted.OobSecp256k1

open SVM.SBPF

/-- `.text` bytes extracted from the .so by qedlift. -/
def OobSecp256k1Bytes : ByteArray := ⟨#[
  0xbf, 0x14, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 
  0x07, 0x01, 0x00, 0x00, 0x00, 0x00, 0x00, 0x10, 
  0xbf, 0x43, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 
  0x07, 0x03, 0x00, 0x00, 0x40, 0x00, 0x00, 0x10, 
  0x07, 0x04, 0x00, 0x00, 0x80, 0x00, 0x00, 0x10, 
  0xb7, 0x02, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 
  0x85, 0x10, 0x00, 0x00, 0x50, 0x03, 0xe4, 0x17, 
  0xb7, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 
  0x95, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00
]⟩

/-- Text section file-offset: 0x100000120. -/
def OobSecp256k1TextOffset : Nat := 0x100000120

/-- Decoded form of the .text bytes. -/
def OobSecp256k1Insns : Array Insn := #[
  .mov64 .r4 (.reg .r1),
  .add64 .r1 (.imm (268435456)),
  .mov64 .r3 (.reg .r4),
  .add64 .r3 (.imm (268435520)),
  .add64 .r4 (.imm (268435584)),
  .mov64 .r2 (.imm (0)),
  .call .sol_secp256k1_recover,
  .mov64 .r0 (.imm (0)),
  .exit
]

/-- The V0 function registry (murmur3 key → target slot) solana-sbpf built
    at load, mirroring `Elf.buildFnRegistry` (audit H2). Resolves internal
    `call` immediates to `.call_local` targets. -/
def OobSecp256k1FnRegistry : List (Nat × Nat) := [(1910755201, 0)]

/-- The bytes decode exactly to the expected instruction array. -/
theorem OobSecp256k1_decodes :
    Decode.decodeProgram OobSecp256k1Bytes OobSecp256k1FnRegistry = some OobSecp256k1Insns := by
  native_decide

/-! ## Symbolically lifted Hoare triple

Synthesised by qedlift's symbolic executor walking the
decoded insns left-to-right. Closed by `sl_block_auto`. -/

open Memory in
theorem OobSecp256k1_lifted_spec
    (baseAddr vR4Old vR3Old vR2Old : Nat)
    : cuTripleWithinMem 6 0 0 6
      (((((((CodeReq.singleton 0 (.mov64 .r4 (.reg .r1))).union
        (CodeReq.singleton 1 (.add64 .r1 (.imm (268435456))))).union
        (CodeReq.singleton 2 (.mov64 .r3 (.reg .r4)))).union
        (CodeReq.singleton 3 (.add64 .r3 (.imm (268435520))))).union
        (CodeReq.singleton 4 (.add64 .r4 (.imm (268435584))))).union
        (CodeReq.singleton 5 (.mov64 .r2 (.imm (0))))))
      ((.r1 ↦ᵣ baseAddr) **
      (.r4 ↦ᵣ vR4Old) **
      (.r3 ↦ᵣ vR3Old) **
      (.r2 ↦ᵣ vR2Old))
      ((.r1 ↦ᵣ wrapAdd baseAddr (toU64 268435456)) **
      (.r4 ↦ᵣ wrapAdd baseAddr (toU64 268435584)) **
      (.r3 ↦ᵣ wrapAdd baseAddr (toU64 268435520)) **
      (.r2 ↦ᵣ toU64 0))
      (fun rt => True) := by
  sl_block_auto

/-! ## Satisfiability witness (soundness-audit H8)

The triple's precondition is SATISFIABLE at the concrete
assignment below — an overlapping (vacuous) sepConj would fail
`native_decide` here, so vacuity cannot ship. The guards pin
each `addrK` literal to its `h_addrK` defining equation at the
assignment; the witness goal is the theorem's precondition with
the variables instantiated, so the reflected `SatWitness` atoms
are tied to the real pre by the elaborator's defeq check.
Value-level path hypotheses (`h_branch*`) are not certified
consistent — they are outside the overlap-vacuity class this
guards against. -/

open Memory in
example : ∃ s,
    ((.r1 ↦ᵣ 0) **
      (.r4 ↦ᵣ 0) **
      (.r3 ↦ᵣ 0) **
      (.r2 ↦ᵣ 0)) s := by
  have w := SatWitness.sat_witness
    [.reg .r1 0,
     .reg .r4 0,
     .reg .r3 0,
     .reg .r2 0]
    (by native_decide)
  exact w

open Memory in
theorem OobSecp256k1_fault_correct
    (baseAddr vR4Old vR3Old vR2Old : Nat)
    (nCuOob : Nat)
    (hCuOob : ∀ s : State,
        (step (.call .sol_secp256k1_recover) s).cuConsumed ≤ s.cuConsumed + nCuOob)
    : cuTripleFaultsWithinMem (6 + 1) (0 + nCuOob) 0
      ((((((((CodeReq.singleton 0 (.mov64 .r4 (.reg .r1))).union
        (CodeReq.singleton 1 (.add64 .r1 (.imm (268435456))))).union
        (CodeReq.singleton 2 (.mov64 .r3 (.reg .r4)))).union
        (CodeReq.singleton 3 (.add64 .r3 (.imm (268435520))))).union
        (CodeReq.singleton 4 (.add64 .r4 (.imm (268435584))))).union
        (CodeReq.singleton 5 (.mov64 .r2 (.imm (0)))))).union
        (CodeReq.singleton 6 (.call .sol_secp256k1_recover)))
      ((.r1 ↦ᵣ baseAddr) **
      (.r4 ↦ᵣ vR4Old) **
      (.r3 ↦ᵣ vR3Old) **
      (.r2 ↦ᵣ vR2Old))
      (fun rt => (True) ∧ rt.containsRange (wrapAdd baseAddr (toU64 268435456)) 32 = false)
      .accessViolation := by
  refine cuTripleWithinMem_seq_fault ?_ (OobSecp256k1_lifted_spec baseAddr vR4Old vR3Old vR2Old) (cuTripleFaultsWithinMem_frame_right ((.r4 ↦ᵣ wrapAdd baseAddr (toU64 268435584)) **
      (.r3 ↦ᵣ wrapAdd baseAddr (toU64 268435520)) **
      (.r2 ↦ᵣ toU64 0))
      (by repeat' apply pcFree_sepConj
          all_goals first
            | exact pcFree_regIs _ _
            | exact pcFree_memU64Is _ _
            | exact pcFree_memU32Is _ _
            | exact pcFree_memU16Is _ _
            | exact pcFree_memByteIs _ _
            | exact pcFree_memBytes32Is _ _
            | exact pcFree_memBytesIs _ _)
      (call_sol_secp256k1_recover_faults_oob_spec (wrapAdd baseAddr (toU64 268435456)) 6 nCuOob hCuOob))
  repeat' apply CodeReq.Disjoint_union_left
  all_goals exact CodeReq.singleton_disjoint_singleton _ _ (by decide)

end Examples.Lifted.OobSecp256k1
