open Memory in
example : ∃ s,
    ((.r3 ↦ᵣ 0) **
      (.r1 ↦ᵣ 0) **
      (.r4 ↦ᵣ 0) **
      (.r2 ↦ᵣ 0)) s := by
  have w := SatWitness.sat_witness
    [.reg .r3 0,
     .reg .r1 0,
     .reg .r4 0,
     .reg .r2 0]
    (by native_decide)
  exact w

