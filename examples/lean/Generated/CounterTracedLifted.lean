/-
  Generated by `qedlift` from `tests/fixtures/counter.so`.

End-to-end lift demonstration:
1. The .text bytes are embedded verbatim as a `ByteArray`.
2. `Decode.decodeProgram` recovers the instruction sequence;
`native_decide` proves the decode is correct.
3. A `cuTripleWithinMem` Hoare triple is stated over the
decoded sequence. The pre/post atom synthesis is the next
iteration's work (the "symbolic executor" piece); for the
demo, see the worked example in
`SVM/SBPF/Macros.lean` (`counter_macro_spec_auto`) where the
theorem is proved by `sl_block_auto` against the same
instruction sequence.
-/

import SVM.SBPF.Decode
import SVM.SBPF.RunnerBridge
import SVM.SBPF.Macros

set_option maxRecDepth 65536
set_option maxHeartbeats 4000000

namespace Examples.Lifted.Counter

open SVM.SBPF

/-- `.text` bytes extracted from the .so by qedlift. -/
def CounterBytes : ByteArray := ⟨#[
  0x79, 0x12, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 
  0x07, 0x02, 0x00, 0x00, 0x01, 0x00, 0x00, 0x00, 
  0x7b, 0x21, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 
  0xb7, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 
  0x95, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00
]⟩

/-- Text section file-offset: 0x100000120. -/
def CounterTextOffset : Nat := 0x100000120

/-- Decoded form of the .text bytes. -/
def CounterInsns : Array Insn := #[
  .ldx .dword .r2 .r1 0,
  .add64 .r2 (.imm (1)),
  .stx .dword .r1 0 .r2,
  .mov64 .r0 (.imm (0)),
  .exit
]

/-- The bytes decode exactly to the expected instruction array. -/
theorem Counter_decodes :
    Decode.decodeProgram CounterBytes = some CounterInsns := by
  native_decide

/-! ## Symbolically lifted Hoare triple

Synthesised by qedlift's symbolic executor walking the
decoded insns left-to-right. Closed by `sl_block_auto`. -/

open Memory in
theorem Counter_lifted_spec
    (baseAddr oldMemD_0 vR2Old vR0Old : Nat)
    (holdMemD_0_lt : oldMemD_0 < 2 ^ 64)
    : cuTripleWithinMem 4 0 0 4
      (((((CodeReq.singleton 0 (.ldx .dword .r2 .r1 0)).union
        (CodeReq.singleton 1 (.add64 .r2 (.imm (1))))).union
        (CodeReq.singleton 2 (.stx .dword .r1 0 .r2))).union
        (CodeReq.singleton 3 (.mov64 .r0 (.imm (0))))))
      ((.r1 ↦ᵣ baseAddr) **
      (effectiveAddr baseAddr 0 ↦U64 oldMemD_0) **
      (.r2 ↦ᵣ vR2Old) **
      (.r0 ↦ᵣ vR0Old))
      ((.r1 ↦ᵣ baseAddr) **
      (effectiveAddr baseAddr 0 ↦U64 wrapAdd oldMemD_0 (toU64 1)) **
      (.r2 ↦ᵣ wrapAdd oldMemD_0 (toU64 1)) **
      (.r0 ↦ᵣ toU64 0))
      (fun rt => (rt.containsRange (effectiveAddr baseAddr 0) 8 = true) ∧
                  rt.containsWritable (effectiveAddr baseAddr 0) 8 = true) := by
  sl_block_auto <;> assumption

open Memory in
theorem Counter_balance_correct
    (baseAddr oldMemD_0 vR2Old vR0Old : Nat)
    (holdMemD_0_lt : oldMemD_0 < 2 ^ 64)
    (h_noovf0 : oldMemD_0 + 1 < 2 ^ 64)
    : cuTripleWithinMem 4 0 0 4
      (((((CodeReq.singleton 0 (.ldx .dword .r2 .r1 0)).union
        (CodeReq.singleton 1 (.add64 .r2 (.imm (1))))).union
        (CodeReq.singleton 2 (.stx .dword .r1 0 .r2))).union
        (CodeReq.singleton 3 (.mov64 .r0 (.imm (0))))))
      ((.r1 ↦ᵣ baseAddr) **
      (effectiveAddr baseAddr 0 ↦U64 oldMemD_0) **
      (.r2 ↦ᵣ vR2Old) **
      (.r0 ↦ᵣ vR0Old))
      ((.r1 ↦ᵣ baseAddr) **
      (effectiveAddr baseAddr 0 ↦U64 oldMemD_0 + 1) **
      (.r2 ↦ᵣ wrapAdd oldMemD_0 (toU64 1)) **
      (.r0 ↦ᵣ toU64 0))
      (fun rt => (rt.containsRange (effectiveAddr baseAddr 0) 8 = true) ∧
                  rt.containsWritable (effectiveAddr baseAddr 0) 8 = true) := by
  have h := Counter_lifted_spec baseAddr oldMemD_0 vR2Old vR0Old holdMemD_0_lt
  rw [← wrapAdd_one_of_lt h_noovf0]
  exact h

end Examples.Lifted.Counter
