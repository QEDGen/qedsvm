/-! ## Demo 11 — `call sol_log_` resolves to the typed `Syscall` variant

We construct the bytecode for `call <Murmur3("sol_log_")>` by embedding
the precomputed hash at decode-time into the immediate field of the
`call` instruction. The decoder runs Murmur3 (via `SyscallHash.fromHash`)
on the hash it reads and produces `.call .sol_log_` — a *typed* dispatch.

This is the load-bearing demo for the syscall dispatch story: it proves
the entire `bytes → Murmur3 → typed Syscall` pipeline is in place. Real
programs from Anchor / Pinocchio / native-Rust / Quasar all encode
their `call` instructions exactly this way. -/

/-- Helper: pack a 32-bit hash as 4 little-endian `UInt8`s. -/
private def hashLE (h : Nat) : Array UInt8 :=
  #[(h % 0x100).toUInt8,
    (h / 0x100 % 0x100).toUInt8,
    (h / 0x10000 % 0x100).toUInt8,
    (h / 0x1000000 % 0x100).toUInt8]

/-- Bytecode for `call sol_log_ ; exit`, built around the precomputed
    Murmur3 hash of the syscall name. -/
def callSolLogBytes : ByteArray :=
  let h := SyscallHash.sol_log_hash
  ⟨#[0x85, 0x00, 0x00, 0x00] ++ hashLE h ++
    #[0x95, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00]⟩

example :
    Decode.decodeProgram callSolLogBytes = some #[.call .sol_log_, .exit] := by
  native_decide

example : Runner.runForExit callSolLogBytes = some 0 := by native_decide

/-! ## Demo 12 — `sol_memcpy_` actually copies bytes

A program that calls `sol_memcpy_` to move 3 bytes from the input
buffer (offset 0) to memory offset 16, then reads back the first
copied byte:

```
  mov64 r2, r1          ; r2 = INPUT_START (src)
  add64 r1, 16          ; r1 = INPUT_START + 16 (dst)
  mov64 r3, 3           ; n = 3
  call sol_memcpy_      ; copies 3 bytes
  ldxb r0, [r1 + 0]     ; read dst[0]
  exit                  ; exit code = dst[0]
```

With `cfg.input = #[0x55, 0x55, 0x55]`, the destination's first byte is
`0x55` after the memcpy, so the exit code is `0x55`. This proves the
typed dispatch *and* real memory-moving syscall semantics work end-to-end. -/

def memcpyDemo : ByteArray :=
  let h := SyscallHash.sol_memcpy_hash
  ⟨#[
    -- mov64 r2, r1
    0xbf, 0x12, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
    -- add64 r1, 16
    0x07, 0x01, 0x00, 0x00, 0x10, 0x00, 0x00, 0x00,
    -- mov64 r3, 3
    0xb7, 0x03, 0x00, 0x00, 0x03, 0x00, 0x00, 0x00
  ] ++ #[0x85, 0x00, 0x00, 0x00] ++ hashLE h ++ #[
    -- ldxb r0, [r1 + 0]
    0x71, 0x10, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
    -- exit
    0x95, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00
  ]⟩

example :
    Runner.runForExit memcpyDemo { input := ⟨#[0x55, 0x55, 0x55]⟩ } = some 0x55 := by
  native_decide

/-! ## Demo 13 — `sol_memset_` fills a region with a constant byte

```
  add64 r1, 16          ; r1 = INPUT_START + 16 (dst)
  mov64 r2, 0xAA        ; val = 0xAA
  mov64 r3, 4           ; n = 4
  call sol_memset_      ; fills 4 bytes with 0xAA
  ldxb r0, [r1 + 2]     ; read dst[2]
  exit                  ; exit code = 0xAA
```
-/

def memsetDemo : ByteArray :=
  let h := SyscallHash.sol_memset_hash
  ⟨#[
    -- add64 r1, 16
    0x07, 0x01, 0x00, 0x00, 0x10, 0x00, 0x00, 0x00,
    -- mov64 r2, 0xAA
    0xb7, 0x02, 0x00, 0x00, 0xaa, 0x00, 0x00, 0x00,
    -- mov64 r3, 4
    0xb7, 0x03, 0x00, 0x00, 0x04, 0x00, 0x00, 0x00
  ] ++ #[0x85, 0x00, 0x00, 0x00] ++ hashLE h ++ #[
    -- ldxb r0, [r1 + 2]
    0x71, 0x10, 0x02, 0x00, 0x00, 0x00, 0x00, 0x00,
    -- exit
    0x95, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00
  ]⟩

example : Runner.runForExit memsetDemo = some 0xAA := by native_decide

/-! ## Demo 14 — `sol_memcmp_` compares two byte ranges and writes the result

```
  mov64 r2, r1          ; r2 = INPUT_START
  add64 r2, 3           ; r2 = INPUT_START + 3 (second range)
  mov64 r4, r1
  add64 r4, 6           ; r4 = INPUT_START + 6 (result address)
  mov64 r3, 3           ; n = 3
  call sol_memcmp_      ; writes i32 to *r4
  ldxb r0, [r4 + 0]     ; low byte of the LE u32 result
  exit
```

We exit with the low byte of the comparison result: 0 if equal, 0xFF
if the first range is less. This is the byte pattern Anchor's
`PubKey::eq` and discriminator checks rely on. -/

def memcmpDemo : ByteArray :=
  let h := SyscallHash.sol_memcmp_hash
  ⟨#[
    -- mov64 r2, r1
    0xbf, 0x12, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
    -- add64 r2, 3
    0x07, 0x02, 0x00, 0x00, 0x03, 0x00, 0x00, 0x00,
    -- mov64 r4, r1
    0xbf, 0x14, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
    -- add64 r4, 6
    0x07, 0x04, 0x00, 0x00, 0x06, 0x00, 0x00, 0x00,
    -- mov64 r3, 3
    0xb7, 0x03, 0x00, 0x00, 0x03, 0x00, 0x00, 0x00
  ] ++ #[0x85, 0x00, 0x00, 0x00] ++ hashLE h ++ #[
    -- ldxb r0, [r4 + 0]
    0x71, 0x40, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
    -- exit
    0x95, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00
  ]⟩

/-- Equal bytes (`AAA` vs `AAA`) → result 0, low byte 0. -/
example : Runner.runForExit memcmpDemo
    { input := ⟨#[0x41, 0x41, 0x41, 0x41, 0x41, 0x41]⟩ } = some 0 := by
  native_decide

/-- Less-than (`AAA` vs `BBB`) → result -1 = 0xFFFFFFFF, low byte 0xFF. -/
example : Runner.runForExit memcmpDemo
    { input := ⟨#[0x41, 0x41, 0x41, 0x42, 0x42, 0x42]⟩ } = some 0xFF := by
  native_decide

/-- Greater-than (`BBB` vs `AAA`) → result 1, low byte 1. -/
example : Runner.runForExit memcmpDemo
    { input := ⟨#[0x42, 0x42, 0x42, 0x41, 0x41, 0x41]⟩ } = some 1 := by
  native_decide

