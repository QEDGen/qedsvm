  0x64, 0x37, 0xb3, 0xac, 0x38, 0x46, 0x51, 0x33,
  0xff, 0xb6, 0x3b, 0x75, 0x27, 0x3a, 0x8d, 0xb5,
  0x48, 0xc5, 0x58, 0x46, 0x5d, 0x79, 0xdb, 0x03,
  0xfd, 0x35, 0x9c, 0x6c, 0xd5, 0xbd, 0x9d, 0x85 ]⟩ := by native_decide

/-- Runner demo: same shape as the sha256 / keccak256 demos, routed
    through the FFI-backed `.sol_blake3` syscall. Exits with the first
    byte of `blake3("abc")` = `0x64`. -/
def blake3Demo : ByteArray :=
  let h := SyscallHash.sol_blake3_hash
  ⟨#[
    -- mov64 r2, 1
    0xb7, 0x02, 0x00, 0x00, 0x01, 0x00, 0x00, 0x00,
    -- mov64 r3, r1
    0xbf, 0x13, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
    -- add64 r3, 64
    0x07, 0x03, 0x00, 0x00, 0x40, 0x00, 0x00, 0x00
  ] ++ #[0x85, 0x00, 0x00, 0x00] ++ hashLE h ++ #[
    -- ldxb r0, [r3 + 0]
    0x71, 0x30, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
