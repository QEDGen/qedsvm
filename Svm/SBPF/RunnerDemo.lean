/-! ## Demo 27 — `sol_secp256k1_recover` via the Rust bridge

ECDSA public-key recovery on the secp256k1 curve, wired through
`rust-bridge` → paritytech's `libsecp256k1 = 0.7.2` (same crate +
version agave uses on master). Solana ABI:
```
sol_secp256k1_recover(
  hash:        *const [u8; 32],
  recovery_id: u64,
  signature:   *const [u8; 64],
  result:      *mut   [u8; 64])
-> u64  -- 0 success | 1 InvalidHash | 2 InvalidRecoveryId | 3 InvalidSignature
```
The recovered public key is the uncompressed form **with the leading
`0x04` byte stripped** (Solana's wire format): `x || y`, 64 bytes.

Test vector (generated by signing a known hash with the deterministic
secret key `seckey[i] = i + 1` using libsecp256k1's
`ecdsa_sign_recoverable`):
```
seckey       = 01 02 03 ... 20
msg hash     = a0 a1 a2 ... bf            (32 bytes)
recovery_id  = 0
signature    = b8ce6c0e … 53bed95f         (64 bytes, compact r||s)
pubkey (64)  = 84bf7562 …  4511acd8        (x || y, no 0x04)
```
-/

/-- Direct sanity check on the FFI — independent of the runner. -/
example :
    Secp256k1.recover
      ⟨#[0xa0, 0xa1, 0xa2, 0xa3, 0xa4, 0xa5, 0xa6, 0xa7,
         0xa8, 0xa9, 0xaa, 0xab, 0xac, 0xad, 0xae, 0xaf,
         0xb0, 0xb1, 0xb2, 0xb3, 0xb4, 0xb5, 0xb6, 0xb7,
         0xb8, 0xb9, 0xba, 0xbb, 0xbc, 0xbd, 0xbe, 0xbf]⟩
      0
      ⟨#[0xb8, 0xce, 0x6c, 0x0e, 0x1c, 0xf8, 0x85, 0xce,
         0xcd, 0x1a, 0x17, 0xc2, 0x8c, 0x67, 0xea, 0xa8,
         0xec, 0x94, 0xd7, 0xc7, 0xfe, 0x89, 0xbe, 0x6c,
         0xf0, 0x8d, 0xb7, 0xdb, 0x75, 0x9d, 0x14, 0xa9,
         0x7d, 0x07, 0x48, 0x2d, 0x17, 0x4a, 0x2a, 0xeb,
         0x9c, 0xe7, 0x50, 0xdf, 0xd6, 0x1a, 0x9a, 0xcb,
         0x3d, 0x58, 0xd7, 0x5c, 0xf7, 0x8c, 0x0c, 0x22,
         0xe7, 0x09, 0xc2, 0xb3, 0x53, 0xbe, 0xd9, 0x5f]⟩
    = .success ⟨#[
        0x84, 0xbf, 0x75, 0x62, 0x26, 0x2b, 0xbd, 0x69,
        0x40, 0x08, 0x57, 0x48, 0xf3, 0xbe, 0x6a, 0xfa,
        0x52, 0xae, 0x31, 0x71, 0x55, 0x18, 0x1e, 0xce,
        0x31, 0xb6, 0x63, 0x51, 0xcc, 0xff, 0xa4, 0xb0,
        0x8c, 0xc4, 0x3d, 0x63, 0xb2, 0x85, 0x9d, 0x46,
        0x9f, 0xee, 0x15, 0xf3, 0x1c, 0x9e, 0xdb, 0x53,
        0x24, 0x26, 0x6e, 0x6f, 0xd0, 0x40, 0x7e, 0x87,
        0x38, 0x2d, 0x60, 0xfc, 0x45, 0x11, 0xac, 0xd8 ]⟩ := by
  native_decide

/-- recovery_id ≥ 4 ⇒ `invalidRecoveryId` (matches agave's
    `RecoveryId::parse` rejection). -/
example :
    Secp256k1.recover ⟨Array.replicate 32 0⟩ 5 ⟨Array.replicate 64 0⟩
    = .invalidRecoveryId := by
  native_decide

/-- All-zero signature is rejected by paritytech's
    `Signature::parse_standard_slice` (`r = 0` is non-canonical) ⇒
    `invalidSignature`. -/
example :
    Secp256k1.recover ⟨Array.replicate 32 0⟩ 0 ⟨Array.replicate 64 0⟩
    = .invalidSignature := by
  native_decide

/-- ECDSA signature malleability: the same `(r, s)` with `s` flipped
    to `N − s` is still a valid signature, but recovers a *different*
    public key. paritytech's `parse_standard_slice` does **not**
    enforce low-S — neither does Bitcoin Core's
    `parse_compact` — so both impls accept both forms. This test
    documents that behavior. -/
example :
    Secp256k1.recover
      ⟨#[0xa0, 0xa1, 0xa2, 0xa3, 0xa4, 0xa5, 0xa6, 0xa7,
         0xa8, 0xa9, 0xaa, 0xab, 0xac, 0xad, 0xae, 0xaf,
         0xb0, 0xb1, 0xb2, 0xb3, 0xb4, 0xb5, 0xb6, 0xb7,
         0xb8, 0xb9, 0xba, 0xbb, 0xbc, 0xbd, 0xbe, 0xbf]⟩
      0
      ⟨#[0xb8, 0xce, 0x6c, 0x0e, 0x1c, 0xf8, 0x85, 0xce,
         0xcd, 0x1a, 0x17, 0xc2, 0x8c, 0x67, 0xea, 0xa8,
         0xec, 0x94, 0xd7, 0xc7, 0xfe, 0x89, 0xbe, 0x6c,
         0xf0, 0x8d, 0xb7, 0xdb, 0x75, 0x9d, 0x14, 0xa9,
         -- s_high = N - s_low (replaces the latter half of the sig)
         0x82, 0xf8, 0xb7, 0xd2, 0xe8, 0xb5, 0xd5, 0x14,
         0x63, 0x18, 0xaf, 0x20, 0x29, 0xe5, 0x65, 0x33,
         0x7d, 0x56, 0x05, 0x89, 0xb7, 0xbc, 0x94, 0x18,
         0xd8, 0xc8, 0x9b, 0xd9, 0x7c, 0x77, 0x67, 0xe2]⟩
    -- Doesn't match the original (which started with 0x84) — different y.
    ≠ Secp256k1.RecoverResult.invalidSignature := by
  native_decide

/-- Runner demo. Input layout:
    - bytes 0..31  : 32-byte message hash
    - bytes 32..95 : 64-byte compact signature
    - bytes 96+    : implicitly zero (output buffer at INPUT_START+128)

```
  mov64 r2, 0                  ; recovery_id = 0
  mov64 r3, r1                 ; r3 = INPUT_START
  add64 r3, 32                 ; r3 = signature ptr
  mov64 r4, r1                 ; r4 = INPUT_START
  add64 r4, 128                ; r4 = output ptr
  call sol_secp256k1_recover
  ldxb r0, [r4 + 0]            ; r0 = recovered_pubkey[0]
  exit
```
Recovered pubkey starts with `0x84`. -/
def secp256k1Demo : ByteArray :=
  let h := SyscallHash.sol_secp256k1_recover_hash
  ⟨#[
    -- mov64 r2, 0
    0xb7, 0x02, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
    -- mov64 r3, r1   (src=1, dst=3 → byte1 = 0x13)
    0xbf, 0x13, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
    -- add64 r3, 32
    0x07, 0x03, 0x00, 0x00, 0x20, 0x00, 0x00, 0x00,
    -- mov64 r4, r1   (src=1, dst=4 → byte1 = 0x14)
    0xbf, 0x14, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
    -- add64 r4, 128
    0x07, 0x04, 0x00, 0x00, 0x80, 0x00, 0x00, 0x00
  ] ++ #[0x85, 0x00, 0x00, 0x00] ++ hashLE h ++ #[
    -- ldxb r0, [r4 + 0]  (src=4, dst=0 → byte1 = 0x40)
    0x71, 0x40, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
    -- exit
    0x95, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00
  ]⟩

def secp256k1DemoInput : ByteArray := ⟨#[
  -- bytes 0..31 : hash
  0xa0, 0xa1, 0xa2, 0xa3, 0xa4, 0xa5, 0xa6, 0xa7,
  0xa8, 0xa9, 0xaa, 0xab, 0xac, 0xad, 0xae, 0xaf,
  0xb0, 0xb1, 0xb2, 0xb3, 0xb4, 0xb5, 0xb6, 0xb7,
  0xb8, 0xb9, 0xba, 0xbb, 0xbc, 0xbd, 0xbe, 0xbf,
