/-
  Verified sBPF runner demos.

  These are **not** part of the production aggregator (`Svm.SBPF`).
  They are example programs that we feed to `Svm.SBPF.Runner.run` and
  prove the exit codes of via `native_decide`. Lean's kernel commits
  to the result of decoding + executing each `ByteArray`.

  Treat this file as integration tests for the runner: editing the
  Decode or Runner code that breaks these should be a build failure.
-/

import Svm.SBPF.Runner
import Svm.SBPF.Pda
import Svm.SBPF.Poseidon
import Svm.SBPF.Bls12_381
import Svm.SBPF.AltBn128
import Svm.SBPF.BigModExp

namespace Svm.SBPF.RunnerDemo

open Svm.SBPF

/-! ## Demo 1 — `mov64 r0, 42; exit`

The "Hello, World!" of sBPF: load 42 into r0 and exit. -/

def helloProgram : ByteArray := ⟨#[
  -- mov64 r0, 42
  0xb7, 0x00, 0x00, 0x00, 0x2a, 0x00, 0x00, 0x00,
  -- exit
  0x95, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00
]⟩

example : Runner.runForExit helloProgram = some 42 := by native_decide

/-! ## Demo 2 — arithmetic: `r0 := 10 + 5; exit` -/

def addProgram : ByteArray := ⟨#[
  -- mov64 r0, 10
  0xb7, 0x00, 0x00, 0x00, 0x0a, 0x00, 0x00, 0x00,
  -- add64 r0, 5
  0x07, 0x00, 0x00, 0x00, 0x05, 0x00, 0x00, 0x00,
  -- exit
  0x95, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00
]⟩

example : Runner.runForExit addProgram = some 15 := by native_decide

/-! ## Demo 3 — register-to-register: `r1 := 7; r0 := r1; exit` -/

def regCopyProgram : ByteArray := ⟨#[
  -- mov64 r1, 7
  0xb7, 0x01, 0x00, 0x00, 0x07, 0x00, 0x00, 0x00,
  -- mov64 r0, r1   (opcode 0xbf, src=r1=1, dst=r0=0 → byte 1 = 0x10)
  0xbf, 0x10, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
  -- exit
  0x95, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00
]⟩

example : Runner.runForExit regCopyProgram = some 7 := by native_decide

/-! ## Demo 4 — conditional skip via `jeq` -/

def condJumpProgram : ByteArray := ⟨#[
  -- jeq r0, 0, +1   (skip the next instruction)
  0x15, 0x00, 0x01, 0x00, 0x00, 0x00, 0x00, 0x00,
  -- mov64 r0, 99    (skipped when jump is taken)
  0xb7, 0x00, 0x00, 0x00, 0x63, 0x00, 0x00, 0x00,
  -- exit
  0x95, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00
]⟩

example : Runner.runForExit condJumpProgram = some 0 := by native_decide

/-! ## Demo 5 — backward loop: count down from 5 to 0 -/

def countdownProgram : ByteArray := ⟨#[
  -- mov64 r0, 5
  0xb7, 0x00, 0x00, 0x00, 0x05, 0x00, 0x00, 0x00,
  -- sub64 r0, 1
  0x17, 0x00, 0x00, 0x00, 0x01, 0x00, 0x00, 0x00,
  -- jne r0, 0, -2  (slot 2 next is slot 3; off = -2 → target slot 1)
  0x55, 0x00, 0xfe, 0xff, 0x00, 0x00, 0x00, 0x00,
  -- exit
  0x95, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00
]⟩

example : Runner.runForExit countdownProgram = some 0 := by native_decide

/-! ## Demo 6 — read from input buffer

Reads a byte from the input buffer at offset 0 (r1 points to INPUT_START)
into r0, then exits. With `cfg.input = #[42, ...]`, the exit code is 42. -/

def readInputProgram : ByteArray := ⟨#[
  -- ldxb r0, [r1 + 0]   (opcode 0x71, dst=r0=0, src=r1=1 → byte 1 = 0x10)
  0x71, 0x10, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
  -- exit
  0x95, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00
]⟩

example :
    Runner.runForExit readInputProgram { input := ⟨#[42]⟩ } = some 42 := by
  native_decide

/-! ## Demo 7 — `lddw` (16-byte instruction) loading a 64-bit constant

Loads 0x0123456789ABCDEF into r0 via `lddw`, then exits. Exercises the
16-byte instruction encoding and the byte-slot → logical-PC remap. -/

def lddwProgram : ByteArray := ⟨#[
  -- lddw r0, 0x0123456789ABCDEF
  -- low 32 bits = 0x89ABCDEF, high 32 bits = 0x01234567
  0x18, 0x00, 0x00, 0x00, 0xef, 0xcd, 0xab, 0x89,
  0x00, 0x00, 0x00, 0x00, 0x67, 0x45, 0x23, 0x01,
  -- exit
  0x95, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00
]⟩

example : Runner.runForExit lddwProgram = some 0x0123456789ABCDEF := by
  native_decide

/-! ## Demo 8 — full ELF64 round trip

A hand-assembled minimal ELF64 sBPF binary containing `mov64 r0, 42; exit`
in its `.text` section, with a `.shstrtab` so the name lookup works.

Layout (289 bytes total):
- bytes 0..63    ELF header (e_shoff = 97, e_shnum = 3, e_shstrndx = 2)
- bytes 64..79   .text data (16 bytes of sBPF bytecode)
- bytes 80..96   .shstrtab data (`\0.text\0.shstrtab\0`)
- bytes 97..160  section header 0 (null)
- bytes 161..224 section header 1 (.text: name=1, type=PROGBITS, off=64, size=16)
- bytes 225..288 section header 2 (.shstrtab: name=7, type=STRTAB, off=80, size=17)

The runner parses the header, walks the section table, matches the
`.text` name, extracts the bytecode, decodes it, and runs it — all
inside Lean's kernel. -/

