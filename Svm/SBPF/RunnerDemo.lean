         0xf0, 0x8d, 0xb7, 0xdb, 0x75, 0x9d, 0x14, 0xa9,
         -- s_high = N - s_low (replaces the latter half of the sig)
         0x82, 0xf8, 0xb7, 0xd2, 0xe8, 0xb5, 0xd5, 0x14,
         0x63, 0x18, 0xaf, 0x20, 0x29, 0xe5, 0x65, 0x33,
