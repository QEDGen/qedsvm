  -- .rel.dyn data (offset 148..163, 16 bytes)
  -- r_offset = 0 (start of lddw in .text)
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
  -- r_info = (1 << 32) | 1 = 0x0000_0001_0000_0001
  0x01, 0x00, 0x00, 0x00, 0x01, 0x00, 0x00, 0x00,
  -- .shstrtab data (offset 164..213, 50 bytes)
