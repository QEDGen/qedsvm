/-! ## Demo 22 — `sol_sha256` hashes "abc" and writes the 32-byte digest

The Solana ABI for `sol_sha256`:
```
sol_sha256(vals: *const SliceDesc, nVals: u64, result: *mut [u8; 32])
```
where each `SliceDesc` is a 16-byte struct `{ ptr: u64, len: u64 }` (LE).

We lay out one descriptor pointing at the bytes `"abc"` (which live at
`INPUT_START + 16` because the descriptor itself occupies the first 16
bytes of the input region), call the syscall, and exit with the first
byte of the digest. `sha256("abc")` begins with `0xba`.

```
  mov64 r2, 1         ; nVals = 1
  mov64 r3, r1        ; r3 = INPUT_START
  add64 r3, 64        ; r3 = INPUT_START + 64 (result buffer)
  call sol_sha256     ; writes 32 bytes at *r3
  ldxb r0, [r3 + 0]   ; r0 = digest[0]
  exit
```
-/

def sha256Demo : ByteArray :=
  let h := SyscallHash.sol_sha256_hash
  ⟨#[
    -- mov64 r2, 1
    0xb7, 0x02, 0x00, 0x00, 0x01, 0x00, 0x00, 0x00,
    -- mov64 r3, r1   (src=r1=1, dst=r3=3 → byte1 = (1<<4)|3 = 0x13)
    0xbf, 0x13, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
    -- add64 r3, 64
    0x07, 0x03, 0x00, 0x00, 0x40, 0x00, 0x00, 0x00
  ] ++ #[0x85, 0x00, 0x00, 0x00] ++ hashLE h ++ #[
    -- ldxb r0, [r3 + 0]   (src=r3=3, dst=r0=0 → byte1 = (3<<4)|0 = 0x30)
    0x71, 0x30, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
    -- exit
    0x95, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00
  ]⟩

/-- Input layout (19 bytes):
    - 0..15  : slice descriptor — ptr = INPUT_START + 16 = 0x400000010, len = 3
    - 16..18 : "abc" = 0x61, 0x62, 0x63
    Result region (INPUT_START + 64 .. + 95) is implicitly zero before the syscall. -/
def sha256DemoInput : ByteArray := ⟨#[
  -- ptr = 0x400000010 (little-endian u64)
  0x10, 0x00, 0x00, 0x00, 0x04, 0x00, 0x00, 0x00,
  -- len = 3 (little-endian u64)
  0x03, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
  -- message = "abc"
  0x61, 0x62, 0x63 ]⟩

example :
    Runner.runForExit sha256Demo { input := sha256DemoInput } = some 0xba := by
  native_decide

