  -- ELF header (64 bytes)
  0x7f, 0x45, 0x4c, 0x46,                          -- magic 0x7f "ELF"
  0x02, 0x01, 0x01, 0x00,                          -- class=64, data=LE, ver=1, abi=SysV
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,  -- abi version + padding
  0x03, 0x00,                                       -- e_type = ET_DYN (3)
  0xf7, 0x00,                                       -- e_machine = EM_BPF (247)
  0x01, 0x00, 0x00, 0x00,                          -- e_version = 1
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,  -- e_entry = 0
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,  -- e_phoff = 0
  0x61, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,  -- e_shoff = 0x61 (97)
  0x00, 0x00, 0x00, 0x00,                          -- e_flags
  0x40, 0x00,                                       -- e_ehsize = 64
  0x00, 0x00,                                       -- e_phentsize = 0
  0x00, 0x00,                                       -- e_phnum = 0
  0x40, 0x00,                                       -- e_shentsize = 64
  0x03, 0x00,                                       -- e_shnum = 3
  0x02, 0x00,                                       -- e_shstrndx = 2
  -- .text data (16 bytes): mov64 r0, 42; exit
  0xb7, 0x00, 0x00, 0x00, 0x2a, 0x00, 0x00, 0x00,
  0x95, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
