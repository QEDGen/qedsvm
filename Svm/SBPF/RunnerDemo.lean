  -- ELF header (64 bytes)
  0x7f, 0x45, 0x4c, 0x46,
  0x02, 0x01, 0x01, 0x00,
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
  0x03, 0x00,                                       -- e_type = ET_DYN
  0xf7, 0x00,                                       -- e_machine = EM_BPF
  0x01, 0x00, 0x00, 0x00,
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,   -- e_entry
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,   -- e_phoff
  0xd6, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,   -- e_shoff = 214
  0x00, 0x00, 0x00, 0x00,
  0x40, 0x00,                                       -- e_ehsize = 64
  0x00, 0x00,                                       -- e_phentsize
  0x00, 0x00,                                       -- e_phnum
  0x40, 0x00,                                       -- e_shentsize = 64
  0x07, 0x00,                                       -- e_shnum = 7
  0x06, 0x00,                                       -- e_shstrndx = 6
  -- .text data (offset 64..95, 32 bytes): lddw r1, 0 (relocated); ldxb r0, [r1+0]; exit
  0x18, 0x01, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
  0x71, 0x10, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
  0x95, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
  -- .rodata data (offset 96, 1 byte): 0x42
  0x42,
  -- .dynsym data (offset 97..144, 48 bytes = 2 × 24)
  -- Symbol 0: null
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
  -- Symbol 1: name=1 ("x"), info=1 (STT_OBJECT), shndx=2 (.rodata), value=0, size=1
